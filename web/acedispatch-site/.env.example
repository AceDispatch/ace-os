# Ace website build-time env (Vite). Copy to .env before `npx vite build`.
# These two are PUBLIC values (safe to ship in the browser bundle):
#   - the project URL, and
#   - the anon / "publishable" key (NOT the secret/service_role key — that never leaves the server).
# The carrier-intake Edge Function is the only thing that holds the service key.

# Supabase project URL (has a sane default baked into OnboardingPage.jsx, but set it explicitly here)
VITE_SUPABASE_URL=https://hsrzysvihamlaupgthrz.supabase.co

# Supabase anon / publishable key — required for the onboarding form to authenticate to the
# carrier-intake function (deployed with verify_jwt=true). Get it from:
# Supabase dashboard -> Project Settings -> API -> Project API keys -> anon / publishable.
VITE_SUPABASE_ANON_KEY=
